{
  "title": "IMS — Incident Management System",
  "uid": "ims-noc-dashboard",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Signals / Second",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "ims_signals_per_second",
        "legendFormat": "sig/s"
      }],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red",    "value": 1000 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Active Incidents",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "ims_active_incidents",
        "legendFormat": "active"
      }],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Queue Fill %",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "ims_queue_fill_ratio * 100",
        "legendFormat": "fill %"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizWidth": 75
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red",    "value": 80 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "WebSocket Clients",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "ims_websocket_clients",
        "legendFormat": "clients"
      }],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Total Signals Ingested",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "ims_signals_ingested_total",
        "legendFormat": "total"
      }],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Signals Per Second — Time Series",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 8 },
      "targets": [
        {
          "expr": "ims_signals_per_second",
          "legendFormat": "signals/sec"
        },
        {
          "expr": "rate(ims_signals_ingested_total[1m]) * 60",
          "legendFormat": "signals/min (rate)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": true
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Work Items by State",
      "type": "piechart",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
      "targets": [
        { "expr": "ims_work_items_by_state{state=\"OPEN\"}",          "legendFormat": "OPEN" },
        { "expr": "ims_work_items_by_state{state=\"INVESTIGATING\"}", "legendFormat": "INVESTIGATING" },
        { "expr": "ims_work_items_by_state{state=\"RESOLVED\"}",     "legendFormat": "RESOLVED" },
        { "expr": "ims_work_items_by_state{state=\"CLOSED\"}",       "legendFormat": "CLOSED" }
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": ["percent", "name"]
      }
    },
    {
      "id": 8,
      "title": "HTTP Request Duration (p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(ims_http_request_duration_seconds_bucket[1m]))",
        "legendFormat": "p95 latency"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 9,
      "title": "Signals Dropped (Backpressure)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "targets": [{
        "expr": "rate(ims_signals_dropped_total[1m])",
        "legendFormat": "drops/sec"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "lineStyle": { "fill": "solid" }
          },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    }
  ]
}
